module gw_gao (
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  wPll_Clk,
  wPhaseVal,
  wWidthVal,
  ESPMode_d,
  tdo_pad_o
)
;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
input wPll_Clk;
input [18:0] wPhaseVal;
input [18:0] wWidthVal;
input [3:0] ESPMode_d;
output tdo_pad_o;
wire tms_i_c;
wire tck_i_c;
wire tdi_i_c;
wire tdo_o_c;
wire gao_jtag_tdi;
wire gao_jtag_reset;
wire run_test_idle_er1;
wire run_test_idle_er2;
wire shift_dr_capture_dr;
wire pause_dr;
wire enable_er1;
wire enable_er2;
wire n12_6;
wire n831_6;
wire [5:0] control0;
wire [4:2] control0_0;
wire [3:0] module_id_reg;
wire [2:0] module_state;
wire VCC;
wire GND;
  IBUF tms_ibuf (
    .O(tms_i_c),
    .I(tms_pad_i) 
);
  IBUF tck_ibuf (
    .O(tck_i_c),
    .I(tck_pad_i) 
);
  IBUF tdi_ibuf (
    .O(tdi_i_c),
    .I(tdi_pad_i) 
);
  OBUF tdo_obuf (
    .O(tdo_pad_o),
    .I(tdo_o_c) 
);
//black box: GW_JTAG u_gw_jtag
  GW_JTAG u_gw_jtag (
    .tck_pad_i(tck_i_c),
    .tms_pad_i(tms_i_c),
    .tdi_pad_i(tdi_i_c),
    .tdo_er1_i(n831_6),
    .tdo_er2_i(GND),
    .tdo_pad_o(tdo_o_c),
    .tck_o(control0[0]),
    .tdi_o(gao_jtag_tdi),
    .test_logic_reset_o(gao_jtag_reset),
    .run_test_idle_er1_o(run_test_idle_er1),
    .run_test_idle_er2_o(run_test_idle_er2),
    .shift_dr_capture_dr_o(shift_dr_capture_dr),
    .pause_dr_o(pause_dr),
    .update_dr_o(control0[5]),
    .enable_er1_o(enable_er1),
    .enable_er2_o(enable_er2) 
);
  gw_con_top u_icon_top (
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .enable_er1(enable_er1),
    .gao_jtag_tdi(gao_jtag_tdi),
    .gao_jtag_reset(gao_jtag_reset),
    .control0_0(control0[0]),
    .control0_5(control0[5]),
    .module_state(module_state[2:0]),
    .n12_6(n12_6),
    .control0_2(control0_0[2]),
    .control0_4(control0_0[4]),
    .module_id_reg(module_id_reg[3:0])
);
  ao_top u_ao_top (
    .n12_6(n12_6),
    .wPll_Clk(wPll_Clk),
    .shift_dr_capture_dr(shift_dr_capture_dr),
    .control0_2(control0_0[2]),
    .control0_4(control0_0[4]),
    .control0_0(control0[0]),
    .control0_5(control0[5]),
    .module_id_reg(module_id_reg[3:0]),
    .wPhaseVal(wPhaseVal[18:0]),
    .wWidthVal(wWidthVal[18:0]),
    .ESPMode_d(ESPMode_d[3:0]),
    .n831_6(n831_6),
    .module_state(module_state[2:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* gw_gao */
module pll_module (
  CLK27_d,
  n27_6,
  wPll_Clk,
  wPll_Lock
)
;
input CLK27_d;
input n27_6;
output wPll_Clk;
output wPll_Lock;
wire clkoutp_o;
wire clkoutd_o;
wire clkoutd3_o;
wire VCC;
wire GND;
